# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# ============================================================================
# FIREBASE CONFIGURATION (Client-Side - Safe for NEXT_PUBLIC_ prefix)
# ============================================================================
# These values are safe to expose in client-side code as they identify your
# Firebase project. Security is enforced through Firebase Security Rules.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ============================================================================
# FIREBASE ADMIN SDK (Server-Side Only - NEVER use NEXT_PUBLIC_ prefix)
# ============================================================================
# These credentials provide full admin access to Firebase. Keep them secure!
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_CLIENT_EMAIL=your_service_account_email_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_private_key_here\n-----END PRIVATE KEY-----\n"

# Alternative: Use service account key file (more secure)
# FIREBASE_SERVICE_ACCOUNT_KEY=/path/to/serviceAccountKey.json

# ============================================================================
# STRIPE PAYMENT PROCESSING
# ============================================================================
# Publishable key (client-side, safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Secret key (server-side only, NEVER expose to client)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook signing secret (for verifying webhook signatures)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================================
# UPSTASH REDIS (Rate Limiting & Caching)
# ============================================================================
# Server-side only - used for distributed rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ============================================================================
# APP CONFIGURATION (Client-Side)
# ============================================================================
NEXT_PUBLIC_APP_NAME=cursuri
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=https://studiai.ro

# ============================================================================
# AZURE SPEECH SERVICE (Client-Side - for video captions)
# ============================================================================
# Note: While these have NEXT_PUBLIC_ prefix, consider moving to API routes
# for better security. Azure Speech API keys should ideally be server-side only.
NEXT_PUBLIC_AZURE_SPEECH_API_KEY=your_azure_speech_api_key_here
NEXT_PUBLIC_AZURE_REGION=your_azure_region_here

# ============================================================================
# AZURE SPEECH SERVICE (Server-Side - lesson AI processing)
# ============================================================================
# Used by /api/admin/lessons/ai-process to transcribe lesson audio and produce
# WEBVTT subtitles. Create a Speech resource in the Azure portal.
AZURE_SPEECH_KEY=your_server_side_azure_speech_key_here
AZURE_SPEECH_REGION=westeurope

# ============================================================================
# AZURE OPENAI / AZURE AI FOUNDRY (Server-Side - lesson summaries)
# ============================================================================
# Used by /api/admin/lessons/ai-process to summarize lesson transcripts.
# Endpoint format: https://<resource-name>.openai.azure.com
# Deployment is the deployment name you created in Azure AI Foundry / Azure
# OpenAI Studio for a chat model (e.g. gpt-4o-mini).
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21
# Image generation (gpt-image-1 / gpt-image-1.5 / gpt-image-2). The deployment
# name MUST match what you created in Azure AI Foundry. The image API version
# must support the chosen model — e.g. 2025-04-01-preview for gpt-image-1.
# Note: do NOT include trailing slashes or whitespace in any of the Azure
# values — Azure's gateway rejects malformed URLs with an HTML 400 page.
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1
AZURE_OPENAI_IMAGE_API_VERSION=2025-04-01-preview

# ============================================================================
# AUDIO EXTRACTOR (Cloud Run Service - Server-Side Only)
# ============================================================================
# The lesson AI pipeline offloads `download video + ffmpeg → mp3` to a
# dedicated Cloud Run service so we don't run ffmpeg on Vercel serverless
# (small /tmp = ENOSPC). See services/audio-extractor/README.md for deploy
# instructions. The service is bearer-token gated; use a high-entropy random
# token (e.g. `[Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes((New-Guid)))`).
AUDIO_EXTRACTOR_URL=https://studiai-audio-extractor-XXXX-ew.a.run.app
AUDIO_EXTRACTOR_TOKEN=replace_with_a_long_random_string

# ============================================================================
# AZURE AD (Server-Side Only - GitHub Account Provisioning)
# ============================================================================
# App Registration with Microsoft Graph APPLICATION permissions:
#   - User.ReadWrite.All           (create + manage Azure AD users)
#   - Application.ReadWrite.All    (assign users to the GitHub EMU app)
#   - Synchronization.ReadWrite.All (trigger SCIM provisionOnDemand)
# All permissions must be admin-consented.
# Without Synchronization.ReadWrite.All the app will return 401/403 on
# provisionOnDemand and will rely on Azure's scheduled sync (~40 min).
AZURE_CLIENT_ID=your_azure_app_registration_client_id_here
AZURE_CLIENT_SECRET=your_azure_app_registration_client_secret_here

# Stripe webhook secret for GitHub account lifecycle
STRIPE_GITHUB_WEBHOOK_SECRET=whsec_your_github_webhook_secret_here

# Stripe webhook secret for the "Book a Call" feature (paid 1-on-1 meetings)
# Configure a separate Stripe webhook endpoint pointing to /api/stripe/meetings-webhook
# subscribed to: checkout.session.completed, checkout.session.expired, checkout.session.async_payment_failed
STRIPE_MEETINGS_WEBHOOK_SECRET=whsec_your_meetings_webhook_secret_here

# Stripe price ID for the GitHub subscription product
# Used by /profile/github ("Buy a new account") and the admin GitHub accounts tab.
# Find it at https://dashboard.stripe.com/prices (must be an ACTIVE recurring price).
NEXT_PUBLIC_STRIPE_GITHUB_PRICE_ID=price_your_github_subscription_price_id_here

# ============================================================================
# GITHUB ENTERPRISE MANAGED USERS (Server-Side Only)
# ============================================================================
# Personal Access Token with `admin:org` scope for the studiai-students org.
# Used to add newly-provisioned EMU users to the organization after SCIM sync.
# Create at: https://github.com/settings/tokens (classic) or fine-grained PAT
# scoped to the studiai-students org with "Members (write)" permission.
GITHUB_ENTERPRISE_TOKEN=ghp_your_github_pat_with_admin_org_scope
# Org slug (defaults to studiai-students if unset)
GITHUB_ORG_SLUG=studiai-students

# ============================================================================
# CRON / SCHEDULED JOBS
# ============================================================================
# Shared secret used to authenticate scheduled invocations. Vercel Cron sends
# this automatically as `Authorization: Bearer $CRON_SECRET` when set as an
# environment variable. Used by /api/cron/repair-github-accounts to retry
# SCIM/org provisioning steps that didn't finish during the Stripe webhook.
CRON_SECRET=generate_a_long_random_string_here

# ============================================================================
# GOOGLE RECAPTCHA v3 (Spam Prevention)
# ============================================================================
# Site key (client-side, safe to expose)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here

# Secret key (server-side only, NEVER expose to client)
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key_here

# ============================================================================
# SENTRY (Error Tracking & Monitoring)
# ============================================================================
# DSN (can be client-side, doesn't expose sensitive data)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Auth token (server-side only, for source map uploads)
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# ============================================================================
# DEVELOPMENT & TESTING
# ============================================================================
NODE_ENV=development
# NODE_ENV=production
# NODE_ENV=test

# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================
# 1. NEVER commit .env.local to version control
# 2. Use NEXT_PUBLIC_ prefix ONLY for non-sensitive, client-safe values
# 3. Keep server-side secrets (Firebase Admin, Stripe Secret) without NEXT_PUBLIC_
# 4. Rotate API keys regularly (at least every 90 days)
# 5. Use different keys for development, staging, and production
# 6. Enable Firebase Security Rules to restrict API access
# 7. Use environment-specific .env files (.env.development, .env.production)
# 8. Consider using a secrets manager (AWS Secrets Manager, Azure Key Vault)
# 9. Monitor API usage for suspicious activity
# 10. Implement rate limiting on all public endpoints

# ============================================================================
# WHAT NEEDS NEXT_PUBLIC_ PREFIX?
# ============================================================================
# ✅ USE NEXT_PUBLIC_ for:
# - Firebase client config (API key, project ID, etc.)
# - Stripe publishable key (pk_test_ or pk_live_)
# - reCAPTCHA site key
# - Public API endpoints
# - App configuration (name, version, public URLs)
# - Analytics tracking IDs (if client-side)
#
# ❌ NEVER USE NEXT_PUBLIC_ for:
# - Firebase Admin credentials
# - Stripe secret key (sk_test_ or sk_live_)
# - Stripe webhook secrets
# - reCAPTCHA secret key
# - Database passwords
# - API secret keys
# - Private encryption keys
# - OAuth client secrets

# ============================================================================
# REQUIRED vs OPTIONAL
# ============================================================================
# Required for basic functionality:
# - All Firebase client config (NEXT_PUBLIC_FIREBASE_*)
# - Firebase Admin SDK credentials (for API routes)
# - Stripe keys (for payments)
#
# Optional (feature-specific):
# - Upstash Redis (improves rate limiting, falls back to in-memory)
# - Azure Speech (only if using video captions feature)
# - reCAPTCHA (only if using contact form)
# - Sentry (only if using error tracking)
